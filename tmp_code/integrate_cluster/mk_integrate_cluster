tmpdir=$(dir  $(abspath $(firstword $(MAKEFILE_LIST))))/
SCRIPT=$(tmpdir)/script
ifdef config
        include $(config)
else
        include $(tmpdir)/config/config.txt
endif

ifdef metadatas
    metadata = --metadata $(metadatas)
endif

