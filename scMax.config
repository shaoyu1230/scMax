# ==========================================================
# scMax 全局环境配置文件 (Global Environment Config)
# ==========================================================
# 此文件定义当前服务器上的默认环境路径。
# 优先级：项目配置(YAML) > 全局配置(scMax.config) > 内置兜底(Script)

# 1. 核心运行时环境
Rscript_path: "Rscript"
python_path: "python3"
jupyter_path: "jupyter"

# 2. 默认输出控制
global_outdir: "./scMax_Out"

# 3. 全局项目与物种信息 (决定结果归档路径与富集库挂载)
# 💡 提示：在此处配齐后，各子模块 YAML (如 03_cluster.yaml) 仅需保留生物学参数
Database_Info:
  run: true                     # 开启数据库注册
  species: "Human"              # 物种: Human / Mouse / Rat ...
  std_project_id: "PM-X123"     # 标准项目编号 (如 PM-X123)
  crm_id: "AN2026xxxxxx"        # CRM 单号
  analyst: "shaoyusong"        # 分析人
  annotation_level: "MajorType" # 默认分群层级
